{
  "name": "synapse-portal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/portal & npm run dev --workspace=apps/api",
    "dev:portal": "npm run dev --workspace=apps/portal",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=@synapse/db && npm run build --workspace=@synapse/api && npm run build --workspace=@synapse/portal",
    "db:generate": "npm run db:generate --workspace=@synapse/db",
    "db:seed": "npm run db:seed --workspace=@synapse/db",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "recharts": "^3.8.1"
  }
}
