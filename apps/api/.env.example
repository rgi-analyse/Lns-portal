# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS
ALLOWED_ORIGIN=http://localhost:3000

# Azure Entra ID – service principal (ikke brukerens konto)
PBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Power BI
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_REPORT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slicer-indeksering scheduler (daglig auto-indeksering)
# SCHEDULER_ENABLED=false dersom du ikke vil at scheduler kjører lokalt
# SCHEDULER_TIME=06:00 (Europe/Oslo) — tidspunkt for daglig kjøring
SCHEDULER_ENABLED=true
SCHEDULER_TIME=06:00
